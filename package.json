{
  "name": "slm-market",
  "version": "7.0.0",
  "description": "SLM Market - Plateforme e-commerce de luxe Enterprise",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --testPathPattern=tests/ --forceExit --detectOpenHandles",
    "test:auth": "jest tests/auth.test.js --forceExit",
    "test:products": "jest tests/products.test.js --forceExit",
    "test:orders": "jest tests/orders.test.js --forceExit",
    "lint": "echo 'No linter configured'"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
